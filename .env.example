# ============================================================
# DroidRaksha — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# API Keys (leave blank to use mock/demo data)
ANTHROPIC_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# Database (SQLite by default — zero setup)
DATABASE_URL=sqlite+aiosqlite:///./droidraksha.db

# Storage (local filesystem for prototype)
UPLOAD_DIR=./uploads

# App settings
DEBUG=true
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
