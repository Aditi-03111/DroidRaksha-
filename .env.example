# ============================================================
# DroidRaksha — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# API Keys (leave blank to use mock/demo data)
ANTHROPIC_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# Database (PostgreSQL via Supabase recommended)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db.xxxx.supabase.co:5432/postgres

# MongoDB (Atlas M0 Cluster recommended)
MONGO_URI=mongodb+srv://username:password@cluster0.xxxx.mongodb.net/droidraksha

# Redis (Upstash recommended)
REDIS_URL=rediss://default:password@us1-xxxx.upstash.io:30000

# Storage (Cloudflare R2 or local)
UPLOAD_DIR=./uploads

# App settings
DEBUG=true
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
